---
// Layout base do site público: SEO + design tokens (§3.7) + tema claro/escuro.
export interface Props {
  title: string;
  description: string;
  path?: string;
}
const { title, description, path = '/' } = Astro.props;
const canonical = new URL(path, Astro.site ?? 'https://niner.com.br').toString();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Open Graph / social (SEO / compartilhamento) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Niner" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index,follow" />
    <!-- base-URL da API lida em runtime, não embutida (spec §3.1) -->
    <script is:inline src="/config.js"></script>
    <style is:global>
      /* Design tokens (§3.7) — tema claro por padrão, escuro por preferência/override. */
      :root {
        --ground: #f5f4f0; --surface: #ffffff; --surface-2: #edece6;
        --field-bg: #e4e6e2; --field-text: #20262a; --label-color: #5c6660;
        --ink: #20262a; --ink-muted: #5c6660;
        --accent: #1f6f6b; --accent-ink: #ffffff;
        --line: #dee2dc; --line-strong: #b9beb5; --danger: #a63d29;
        --radius: 10px; --maxw: 1080px;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --ground: #12181a; --surface: #1a2225; --surface-2: #202a2d;
          --field-bg: #2a3336; --field-text: #e7ecec; --label-color: #93a19e;
          --ink: #e7ecec; --ink-muted: #93a19e;
          --accent: #4fbdb2; --accent-ink: #0b1416;
          --line: #2a3538; --line-strong: #4a5457; --danger: #e2836a;
        }
      }
      :root[data-theme='light'] {
        --ground: #f5f4f0; --surface: #ffffff; --surface-2: #edece6;
        --field-bg: #e4e6e2; --field-text: #20262a; --label-color: #5c6660;
        --ink: #20262a; --ink-muted: #5c6660; --accent: #1f6f6b; --accent-ink: #ffffff;
        --line: #dee2dc; --line-strong: #b9beb5; --danger: #a63d29;
      }
      :root[data-theme='dark'] {
        --ground: #12181a; --surface: #1a2225; --surface-2: #202a2d;
        --field-bg: #2a3336; --field-text: #e7ecec; --label-color: #93a19e;
        --ink: #e7ecec; --ink-muted: #93a19e; --accent: #4fbdb2; --accent-ink: #0b1416;
        --line: #2a3538; --line-strong: #4a5457; --danger: #e2836a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--ground); color: var(--ink);
        font: 16px/1.6 system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      a { color: var(--accent); }
      .container { max-width: var(--maxw); margin: 0 auto; padding: 0 20px; }
      .site-header, .site-footer { background: var(--surface-2); border-color: var(--line); }
      .site-header { border-bottom: 1px solid var(--line); }
      .site-footer { border-top: 1px solid var(--line); margin-top: 64px; color: var(--ink-muted); }
      .bar { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { font-weight: 700; letter-spacing: .5px; color: var(--ink); text-decoration: none; }
      .brand span { color: var(--accent); }
      .btn {
        display: inline-block; padding: 12px 20px; border-radius: var(--radius);
        background: var(--accent); color: var(--accent-ink); font-weight: 600;
        text-decoration: none; border: 0; cursor: pointer; font-size: 15px;
      }
      .btn.ghost { background: transparent; color: var(--accent); border: 1px solid var(--line-strong); }
      .card {
        background: var(--surface); border: 1px solid var(--line);
        border-radius: var(--radius); padding: 24px;
      }
      label { display: block; color: var(--label-color); font-size: 13px; margin: 14px 0 6px; }
      input {
        width: 100%; padding: 12px 14px; border-radius: 8px;
        background: var(--field-bg); color: var(--field-text); border: 1px solid var(--line-strong);
        font-size: 15px;
      }
      h1 { font-size: clamp(30px, 5vw, 46px); line-height: 1.15; margin: 0 0 16px; }
      .eyebrow { color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; font-size: 13px; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container bar">
        <a class="brand" href="/">NI<span>NER</span></a>
        <nav style="display:flex; gap:16px; align-items:center;">
          <a href="/#planos" style="text-decoration:none; color:var(--ink-muted);">Planos</a>
          <a class="btn" href="/assinar">Testar grátis</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container" style="padding-top:24px; padding-bottom:24px;">
        Niner — ERP para varejo multicanal. © Vetor Sistemas.
      </div>
    </footer>
  </body>
</html>
